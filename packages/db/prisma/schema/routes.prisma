model Route {
  id            String   @id @default(cuid())
  title         String
  description   String?
  isPublic      Boolean  @default(false) @map("is_public")
  source        String?
  sourceReference String? @map("source_reference")
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "routes_user_id_fkey")
  mainVersionId String?  @map("main_version_id")
  mainVersion   RouteVersion? @relation("RouteMainVersion", fields: [mainVersionId], references: [id], onDelete: SetNull, map: "routes_main_version_id_fkey")
  versions      RouteVersion[] @relation("RouteVersions")
  votes         RouteVote[]
  comments      RouteComment[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "routes_user_id_idx")
  @@index([mainVersionId], map: "routes_main_version_id_idx")
  @@unique([userId, sourceReference], map: "routes_user_id_source_reference_key")
  @@map("routes")
}

enum RouteVersionSourceType {
  edit
  upload
}

model RouteVersion {
  id               String                 @id @default(cuid())
  routeId          String                 @map("route_id")
  route            Route                  @relation("RouteVersions", fields: [routeId], references: [id], onDelete: Cascade, map: "route_versions_route_id_fkey")
  sourceType       RouteVersionSourceType @map("source_type")
  originalFileName String?                @map("original_file_name")
  gpxFileName      String                 @map("gpx_file_name")
  geoJsonFileName  String                 @map("geojson_file_name")
  versionOrder     Int                    @map("version_order")
  distance         Float?
  elevationGain    Float?                 @map("elevation_gain")
  elevationLoss    Float?                 @map("elevation_loss")
  minElevation     Float?                 @map("min_elevation")
  maxElevation     Float?                 @map("max_elevation")
  bboxNorth        Float?                 @map("bbox_north")
  bboxSouth        Float?                 @map("bbox_south")
  bboxEast         Float?                 @map("bbox_east")
  bboxWest         Float?                 @map("bbox_west")
  mainForRoute     Route[]                @relation("RouteMainVersion")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  @@index([routeId], map: "route_versions_route_id_idx")
  @@index([routeId, createdAt], map: "route_versions_route_id_created_at_idx")
  @@unique([routeId, versionOrder], map: "route_versions_route_id_version_order_key")
  @@map("route_versions")
}

enum RouteVoteValue {
  up
  down
}

model RouteVote {
  id        String         @id @default(cuid())
  routeId   String         @map("route_id")
  route     Route          @relation(fields: [routeId], references: [id], onDelete: Cascade, map: "route_votes_route_id_fkey")
  userId    String         @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "route_votes_user_id_fkey")
  value     RouteVoteValue
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@unique([routeId, userId], map: "route_votes_route_id_user_id_key")
  @@index([routeId], map: "route_votes_route_id_idx")
  @@index([userId], map: "route_votes_user_id_idx")
  @@map("route_votes")
}

model RouteComment {
  id        String         @id @default(cuid())
  routeId   String         @map("route_id")
  route     Route          @relation(fields: [routeId], references: [id], onDelete: Cascade, map: "route_comments_route_id_fkey")
  userId    String         @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade, map: "route_comments_user_id_fkey")
  parentId  String?        @map("parent_id")
  parent    RouteComment?  @relation("RouteCommentReplies", fields: [parentId], references: [id], onDelete: Cascade, map: "route_comments_parent_id_fkey")
  replies   RouteComment[] @relation("RouteCommentReplies")
  content   String
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@index([routeId], map: "route_comments_route_id_idx")
  @@index([userId], map: "route_comments_user_id_idx")
  @@index([parentId], map: "route_comments_parent_id_idx")
  @@map("route_comments")
}
